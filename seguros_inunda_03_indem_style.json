          ["get", "class"],
          ["primary", "secondary", "tertiary", "trunk"],
          true,
          false
        ]
      ],
      "layout": {"line-cap": "round", "line-join": "round"},
      "paint": {
        "line-color": "rgba(25, 25, 25, 1)",
        "line-width": [
          "interpolate",
          ["exponential", 1.3],
