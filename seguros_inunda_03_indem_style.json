      "paint": {
        "fill-color": "hsl(0,0%,98%)",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 0, 1, 8, 0.5]
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "maxzoom": 16,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "class"], "residential"]
