{
  "version": 8,
  "metadata": {"maputnik:renderer": "mlgljs"},
  "sources": {
    "ne2_shaded": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": [
        "https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"
      ],
      "type": "raster"
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    },
    "calles": {
      "type": "geojson",
      "data": "https://raw.githubusercontent.com/encarnihinojosa/mapasSUR/refs/heads/main/calles_mujeres_malaga.json"
    },
    "indem": {
      "type": "geojson",
      "data": "https://raw.githubusercontent.com/encarnihinojosa/seguros_inundaciones/refs/heads/main/seguros_inunda_01_indem.json"
    },
    "siniestros": {
      "type": "geojson",
      "data": "https://raw.githubusercontent.com/encarnihinojosa/seguros_inundaciones/refs/heads/main/seguros_inunda_02_siniestros.json"
    },
    "yxxvdv2": {
      "type": "vector",
      "url": "https://localhost:3000/tilejson.json"
    },
    "tasa": {
      "type": "geojson",
      "data": "https://raw.githubusercontent.com/encarnihinojosa/seguros_inundaciones/refs/heads/main/seguros_inunda_03_tasa.json"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {"background-color": "rgb(12,12,12)"}
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "filter": [
        "match",
        ["geometry-type"],
        ["MultiPolygon", "Polygon"],
        true,
        false
      ],
      "paint": {"fill-color": "rgba(0, 0, 0, 1)"}
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["!=", ["get", "brunnel"], "tunnel"]
      ],
      "paint": {"fill-antialias": true, "fill-color": "rgb(30,30,30)"}
    },
    {
      "id": "landcover_ice_shelf",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "maxzoom": 8,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "subclass"], "ice_shelf"]
      ],
      "paint": {"fill-color": "hsl(0,0%,98%)", "fill-opacity": 0.7}
    },
    {
      "id": "landcover_glacier",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "maxzoom": 8,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "subclass"], "glacier"]
